# Inventory Frontend Development Configuration

# API Base URLs
VITE_API_BASE_URL=http://localhost:8082
VITE_DIRECTORY_API_URL=http://localhost:9000

# Cookie Configuration (for reference only - actual cookie is HttpOnly server-side)
VITE_COOKIE_DOMAIN=localhost
VITE_COOKIE_SECURE=false
VITE_COOKIE_MAX_AGE=86400

# API Timeout
VITE_API_TIMEOUT=30000

# OAuth2
VITE_OAUTH2_REDIRECT_ENABLED=true

# Debug Mode
VITE_DEBUG=true
