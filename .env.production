# Inventory Frontend Production Configuration

# API Base URLs
VITE_API_BASE_URL=https://api-inventory.zenohosp.com
VITE_DIRECTORY_API_URL=https://api-directory.zenohosp.com

# Cookie Configuration (for reference only - actual cookie is HttpOnly server-side)
VITE_COOKIE_DOMAIN=.zenohosp.com
VITE_COOKIE_SECURE=true
VITE_COOKIE_MAX_AGE=86400

# API Timeout
VITE_API_TIMEOUT=30000

# OAuth2
VITE_OAUTH2_REDIRECT_ENABLED=true

# Debug Mode
VITE_DEBUG=false
